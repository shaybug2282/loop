{
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "devCommand": "npm install serve-favicon, npm start",
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
    
  ]
}
